---
import BaseHead from '../components/BaseHead.astro';
import Header   from '../components/Header.astro';
import Footer   from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead
      title={`Tarifs coaching · ${SITE_TITLE}`}
      description="Coaching personnalisé pour intégrer plus de mouvement dans ta vie : mobilité & Pilates, renforcement musculaire et running. Accompagnement en présentiel (250 €/mois) ou à distance (150 €/mois)."
    />
  </head>

  <body class="antialiased">
    <Header />

    <!-- INTRO ---------------------------------------------------------->
    <section class="bg-[#FFFCFA] relative w-full px-4 py-12 md:py-16 flex flex-col items-center text-center">
      <p class="text-xs font-semibold tracking-widest text-[#d89a6b] uppercase mb-4">
        Coaching · Accompagnement du mouvement
      </p>

      <h1 class="text-4xl md:text-6xl font-extrabold text-[#331c10] mb-6">
        Tarifs coaching
      </h1>

      <div class="max-w-2xl space-y-4 text-[#331c10] leading-relaxed">
        <p class="text-lg">
          Tu as envie d’intégrer <strong>plus de mouvement</strong> dans ta vie ?
          Tu sens que tu as besoin de bouger plus mais tu ne sais pas comment t’y prendre ?
        </p>
        <p class="text-[#331c10]/80">
          Je propose des <strong>suivis personnalisés</strong>, adaptés à ton rythme de vie,
          pour intégrer durablement plus de mouvement au quotidien — autour de trois piliers.
        </p>
      </div>

      <a
        href="#accompagnements"
        class="mt-8 inline-block rounded-lg bg-[#d89a6b] px-6 py-3
               !text-black font-semibold tracking-wide no-underline
               hover:!text-white hover:bg-[#331c10]
               focus:outline-none focus-visible:ring-2 focus-visible:ring-[#331c10] focus-visible:ring-offset-2"
      >
        Voir les accompagnements
      </a>
    </section>

    <!-- LES PILIERS : 3 CARRÉS ----------------------------------------->
    <section class="bg-[#FFD6BA] py-16">
      <div class="max-w-6xl mx-auto px-4">
        <div class="grid gap-8 sm:grid-cols-3">
          <!-- Mobilité & Pilates -->
          <div class="flex flex-col items-center rounded-2xl bg-white shadow-xl p-8 transition hover:-translate-y-1 hover:shadow-2xl">
            <img src="/yoga.png" alt="Mobilité et Pilates" class="h-20 w-20 object-contain mb-5" />
            <h3 class="text-xl font-semibold text-[#331c10] mb-2 text-center">Mobilité &amp; Pilates</h3>
            <p class="text-center text-sm text-[#331c10]/70">
              Posture, souplesse et conscience du corps.
            </p>
          </div>

          <!-- Renforcement musculaire -->
          <div class="flex flex-col items-center rounded-2xl bg-white shadow-xl p-8 transition hover:-translate-y-1 hover:shadow-2xl">
            <svg class="h-20 w-20 object-contain mb-5" viewBox="0 0 24 24" fill="none"
                 stroke="#331c10" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"
                 role="img" aria-label="Renforcement musculaire">
              <path d="M7 12h10" /><path d="M7 7v10" /><path d="M17 7v10" />
              <path d="M4 8.5v7" /><path d="M20 8.5v7" />
            </svg>
            <h3 class="text-xl font-semibold text-[#331c10] mb-2 text-center">Renforcement musculaire</h3>
            <p class="text-center text-sm text-[#331c10]/70">
              Force, stabilité et tonicité.
            </p>
          </div>

          <!-- Running -->
          <div class="flex flex-col items-center rounded-2xl bg-white shadow-xl p-8 transition hover:-translate-y-1 hover:shadow-2xl">
            <img src="/runner.png" alt="Running" class="h-20 w-20 object-contain mb-5" />
            <h3 class="text-xl font-semibold text-[#331c10] mb-2 text-center">Running</h3>
            <p class="text-center text-sm text-[#331c10]/70">
              Endurance et cardio, à ton rythme.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- LES ACCOMPAGNEMENTS : 2 CARTES TARIFS --------------------------->
    <section id="accompagnements" class="bg-[#FFFCFA] py-16 scroll-mt-24">
      <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-10">
          <h2 class="text-3xl md:text-4xl font-extrabold text-[#331c10]">Les accompagnements</h2>
          <p class="mt-3 max-w-2xl mx-auto text-[#331c10] leading-relaxed">
            Deux formules au choix selon tes besoins et ta disponibilité.
          </p>
        </div>

        <div class="grid gap-8 md:gap-10 md:grid-cols-2 items-stretch">
          <!-- PRÉSENTIEL ------------------------------------------------->
          <div class="flex flex-col rounded-2xl bg-white shadow-xl overflow-hidden transition hover:-translate-y-1 hover:shadow-2xl">
            <img
              src="/coaching-presentiel.png"
              alt="Coaching en présentiel à domicile"
              class="aspect-[16/9] w-full object-cover"
            />

            <div class="flex flex-col flex-1 p-8 md:p-9">
              <div class="mb-4 flex items-center justify-between gap-3">
                <span class="inline-flex rounded-full bg-[#331c10]/5 px-3 py-1 text-xs font-semibold text-[#331c10]">
                  En présentiel
                </span>
                <span class="text-3xl md:text-4xl font-extrabold text-[#331c10]">
                  250 €<span class="text-base font-semibold text-[#331c10]/60"> / mois</span>
                </span>
              </div>

              <h3 class="text-xl md:text-2xl font-semibold text-[#331c10] mb-2">Coaching en présentiel</h3>
              <p class="text-sm text-[#331c10]/70 mb-5">
                📍 Agglomération de Cergy-Pontoise (95) et alentours.
              </p>

              <p class="text-sm font-semibold text-[#331c10] mb-3">Ce qui est inclus :</p>
              <ul class="space-y-2 text-[#331c10] text-[15px] leading-snug mb-8">
                <li>✓ Un bilan de départ pour définir tes objectifs</li>
                <li>✓ 4 séances en présentiel</li>
                <li>✓ Des conseils nutrition</li>
                <li>✓ Des séances type à faire de ton côté</li>
                <li>✓ Un suivi WhatsApp 5j/7</li>
              </ul>

              <a
                href="/contact#contact-form"
                class="mt-auto inline-block text-center rounded-lg bg-[#d89a6b] px-6 py-3
                       !text-black font-semibold tracking-wide no-underline
                       hover:!text-white hover:bg-[#331c10]
                       focus:outline-none focus-visible:ring-2 focus-visible:ring-[#331c10] focus-visible:ring-offset-2"
              >
                Je me lance
              </a>
            </div>
          </div>

          <!-- À DISTANCE ------------------------------------------------->
          <div class="flex flex-col rounded-2xl bg-white shadow-xl overflow-hidden transition hover:-translate-y-1 hover:shadow-2xl">
            <img
              src="/coaching-distance.png"
              alt="Coaching à distance"
              class="aspect-[16/9] w-full object-cover object-top"
            />

            <div class="flex flex-col flex-1 p-8 md:p-9">
              <div class="mb-4 flex items-center justify-between gap-3">
                <span class="inline-flex rounded-full bg-[#331c10]/5 px-3 py-1 text-xs font-semibold text-[#331c10]">
                  À distance
                </span>
                <span class="text-3xl md:text-4xl font-extrabold text-[#331c10]">
                  150 €<span class="text-base font-semibold text-[#331c10]/60"> / mois</span>
                </span>
              </div>

              <h3 class="text-xl md:text-2xl font-semibold text-[#331c10] mb-2">Coaching à distance</h3>
              <p class="text-sm text-[#331c10]/70 mb-5">
                🌍 Partout, à la maison ou en salle de sport.
              </p>

              <p class="text-sm font-semibold text-[#331c10] mb-3">Ce qui est inclus :</p>
              <ul class="space-y-2 text-[#331c10] text-[15px] leading-snug mb-8">
                <li>✓ Un bilan de départ pour définir tes objectifs</li>
                <li>✓ 2 ou 3 séances par semaine à faire à la maison ou en salle</li>
                <li>✓ Un point à distance toutes les 2 semaines</li>
                <li>✓ Un suivi WhatsApp 5j/7</li>
              </ul>

              <a
                href="/contact#contact-form"
                class="mt-auto inline-block text-center rounded-lg bg-[#d89a6b] px-6 py-3
                       !text-black font-semibold tracking-wide no-underline
                       hover:!text-white hover:bg-[#331c10]
                       focus:outline-none focus-visible:ring-2 focus-visible:ring-[#331c10] focus-visible:ring-offset-2"
              >
                Je me lance
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA FINALE ----------------------------------------------------->
    <section class="bg-white py-16">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <h2 class="text-2xl md:text-3xl font-extrabold text-[#331c10] mb-4">
          Prêt·e à intégrer plus de mouvement ?
        </h2>
        <p class="text-[#331c10]/80 mb-8">
          Parle-moi de tes objectifs, on construit ensemble l’accompagnement qui te correspond.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a
            href="/contact#contact-form"
            class="inline-block rounded-lg bg-[#331c10] px-6 py-3
                   !text-white font-semibold tracking-wide no-underline
                   hover:bg-[#2a160d]
                   focus:outline-none focus-visible:ring-2 focus-visible:ring-[#331c10] focus-visible:ring-offset-2"
          >
            Demander un accompagnement
          </a>
          <a
            href="/contact"
            class="inline-block rounded-lg border border-[#331c10]/20 bg-white px-6 py-3
                   !text-[#331c10] font-semibold tracking-wide no-underline
                   hover:bg-[#331c10]/5
                   focus:outline-none focus-visible:ring-2 focus-visible:ring-[#331c10] focus-visible:ring-offset-2"
          >
            Contactez-moi
          </a>
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html>
